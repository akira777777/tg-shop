# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=your_bot_username
ADMIN_CHAT_IDS=123456789
ADMIN_CHANNEL_ID=-100123456789
MINI_APP_URL=https://your-deployment.vercel.app/
WEBHOOK_SECRET=generate_a_random_secret_here

# ── TRC20 USDT ───────────────────────────────────────────────────────────────
TRON_DEPOSIT_ADDRESS_POOL=T_your_trc20_address_1,T_your_trc20_address_2
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRONGRID_API_KEY=
TRONGRID_API_URL=https://api.trongrid.io
PAYMENT_CONFIRMATIONS_REQUIRED=1

# ── TON ──────────────────────────────────────────────────────────────────────
TON_WALLET_ADDRESS=your_ton_wallet_address
TONCENTER_API_KEY=
TONCENTER_API_URL=https://toncenter.com/api/v2

# ── Order TTL ────────────────────────────────────────────────────────────────
ORDER_TTL_MINUTES=30

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
UPSTASH_REDIS_URL=rediss://default:your_upstash_token@your-instance.upstash.io:6380

# ── Security ─────────────────────────────────────────────────────────────────
CRON_SECRET=generate_a_random_secret_here

# ── Dev only ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ALLOW_DEV_AUTH=false
NEXT_PUBLIC_DEV_TELEGRAM_USER_ID=
