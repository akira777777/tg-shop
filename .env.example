# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather after creating your bot
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Bot username without @ (used by Chat SDK)
TELEGRAM_BOT_USERNAME=your_bot_username

# Comma-separated Telegram user IDs for admin access
ADMIN_CHAT_IDS=123456789,987654321

# Optional: Telegram channel ID for payment notifications (e.g. -1001234567890)
ADMIN_CHANNEL_ID=

# Your deployed Vercel URL (set after first deploy)
MINI_APP_URL=https://your-app.vercel.app

# Random secret set when registering the webhook:
# curl -X POST "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#   -d "url=https://your-app.vercel.app/api/telegram/webhook" \
#   -d "secret_token=<WEBHOOK_SECRET>"
WEBHOOK_SECRET=

# ── TRC20 USDT ───────────────────────────────────────────────────────────────
# Comma-separated TRC20 deposit addresses for the address pool
TRON_DEPOSIT_ADDRESS_POOL=TAddr1,TAddr2,TAddr3

# Mainnet USDT TRC20 contract (do not change unless using testnet)
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# TronGrid API key (free at trongrid.io — increases rate limits)
TRONGRID_API_KEY=
TRONGRID_API_URL=https://api.trongrid.io

# Number of confirmations required before marking payment as confirmed (default 1)
PAYMENT_CONFIRMATIONS_REQUIRED=1

# ── TON ──────────────────────────────────────────────────────────────────────
# Single TON receiving wallet address
TON_WALLET_ADDRESS=

# TonCenter API key (optional — increases rate limits)
TONCENTER_API_KEY=
TONCENTER_API_URL=https://toncenter.com/api/v2

# ── Order TTL ────────────────────────────────────────────────────────────────
# Minutes before an unpaid order expires (TRC20 default 30, TON default 60)
ORDER_TTL_MINUTES=30

# ── Database ─────────────────────────────────────────────────────────────────
# Neon connection string from Vercel Marketplace integration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noct2

# ── Redis ────────────────────────────────────────────────────────────────────
# Upstash Redis REST API (for product cache, address pool, TON price cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash Redis connection URL (for Chat SDK state adapter)
UPSTASH_REDIS_URL=rediss://default:token@endpoint:6379

# ── Security ─────────────────────────────────────────────────────────────────
# Random secret to authenticate cron invocations — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Dev only ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ALLOW_DEV_AUTH=false
NEXT_PUBLIC_DEV_TELEGRAM_USER_ID=
