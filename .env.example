# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather after creating your bot
TELEGRAM_BOT_TOKEN=8733321177:AAFRrWfDN0I6961MRVKZlkPityEyfMjkf7I

# Your admin group chat ID — negative number, e.g. -1001234567890
# Add the bot to the group, send a message, call getUpdates to find it
ADMIN_GROUP_ID=5024607998

# Your deployed Vercel URL (set after first deploy)
MINI_APP_URL=https://your-app.vercel.app

# Random secret set when registering the webhook:
# curl -X POST "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#   -d "url=https://your-app.vercel.app/api/telegram/webhook" \
#   -d "secret_token=<WEBHOOK_SECRET>"
WEBHOOK_SECRET=

# ── USDT / TRC20 ──────────────────────────────────────────────────────────────
# 64-byte hex seed for HD wallet derivation — generate once with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit or share this value — it controls all payment addresses
HD_WALLET_SEED=

# Mainnet USDT TRC20 contract (do not change unless using testnet)
USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# TronGrid API key (free at trongrid.io — increases rate limits)
TRONGRID_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Neon connection string from Vercel Marketplace integration
DATABASE_URL=DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noct2


# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash Redis from Vercel Marketplace integration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Security ──────────────────────────────────────────────────────────────────
# Random secret to authenticate cron invocations — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
